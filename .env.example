# Databricks Configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi1234567890abcdef

# Catálogo e Schemas
CATALOGO=ecommerce
SCHEMA_BRONZE=bronze
SCHEMA_SILVER=silver
SCHEMA_GOLD=gold

# Paths no Lakehouse
VOLUME_PATH=/Volumes/ecommerce/bronze/raw_data

# API Banco Central
BCB_API_URL=https://olinda.bcb.gov.br/olinda/servico/Moeda_Estrangeira/versao/v1
BCB_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
